# ─────────────────────────────────────────────────────────────────
#  HQG Security SOC Platform – environment variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# URL used by the browser fetch calls.
# Leave as "/api/os" to route through the Vite dev-server proxy (recommended).
# In production set to the full URL and configure a reverse-proxy (nginx) for
# CORS and TLS termination.
VITE_WAZUH_URL=/api/os

# OpenSearch / Wazuh Indexer credentials (embedded in browser bundle – use a
# read-only role scoped to wazuh-alerts-* for security).
VITE_WAZUH_USER=admin
VITE_WAZUH_PASSWORD=SecurePassword123

# ── Vite dev-server proxy (only used during "npm run dev") ────────
# The Vite proxy forwards "/api/os/*" to this target, handles TLS
# and injects the Authorization header so the browser never deals
# with CORS or self-signed certificates.
VITE_WAZUH_TARGET=https://localhost:9200
