# ─────────────────────────────────────────────────────────────────
#  HQG Security SOC Platform – environment variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── API base URL ──────────────────────────────────────────────────
# Leave as "/api/os" for both dev (Vite proxy) and production (nginx proxy).
# The proxy handles CORS and TLS — the browser never contacts OpenSearch directly.
VITE_WAZUH_URL=/api/os

# ── OpenSearch credentials ─────────────────────────────────────────
# ⚠️  SECURITY: These values are embedded in the JS bundle.
#    In PRODUCTION, set these to a READ-ONLY OpenSearch user scoped to
#    wazuh-alerts-* only.  Admin credentials MUST NOT be used here.
#    Better: leave both empty and let nginx inject the Authorization
#    header server-side (see nginx.conf for instructions).
VITE_WAZUH_USER=soc-readonly
VITE_WAZUH_PASSWORD=CHANGE_ME

# ── Vite dev-server proxy (only used during "npm run dev") ─────────
# Forwards /api/os/* → OpenSearch, handles self-signed TLS.
VITE_WAZUH_TARGET=https://localhost:9200

# ── Optional tuning ────────────────────────────────────────────────
# VITE_WAZUH_TIMEOUT_MS=12000
# VITE_WAZUH_ALERTS_SIZE=500

# ── Attack map target coordinates (SOC location) ──────────────────
# Defaults to Hanoi (105.8342, 21.0278) if not set.
# VITE_SOC_TARGET_LON=105.8342
# VITE_SOC_TARGET_LAT=21.0278
